{
  "name": "promptforge-api",
  "type": "DOCKER",
  "docker": {
    "entrypoint": "uvicorn",
    "command": "api:app --host 0.0.0.0 --port 8000 --workers 1"
  },
  "ports": [
    {
      "port": 8000,
      "path": "/",
      "protocols": ["HTTP"]
    }
  ],
  "health": {
    "path": "/health",
    "interval": 30,
    "timeout": 10,
    "start_period": 40
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "scaling": {
    "min": 1,
    "max": 3
  }
}
