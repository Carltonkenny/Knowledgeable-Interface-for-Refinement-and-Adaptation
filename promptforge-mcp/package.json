{
  "name": "@promptforge/mcp-server",
  "version": "1.0.0",
  "description": "PromptForge MCP Server — Connect Kira's prompt engineering swarm to any MCP-compatible IDE (Cursor, Claude Desktop, Windsurf, etc.)",
  "main": "dist/index.js",
  "bin": {
    "promptforge-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "promptforge",
    "kira",
    "prompt-engineering",
    "cursor",
    "claude-desktop"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
