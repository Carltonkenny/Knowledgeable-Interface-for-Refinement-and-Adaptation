# .env.example
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Pollinations Gen API (Official)
# Get API key from: https://gen.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1
POLLINATIONS_MODEL_FULL=openai
POLLINATIONS_MODEL_FAST=nova

# Alternative: Groq API (optional, faster)
# GROQ_API_KEY=your_groq_api_key_here

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_KEY=your_service_role_key_here

# Frontend URLs (for CORS) - comma-separated list
# Localhost + production Koyeb URL
FRONTEND_URLS=http://localhost:3000,https://your-app.koyeb.app

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Optional: OpenAI API (if not using Pollinations)
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (for LangMem embeddings)
# Get API key from: https://aistudio.google.com/app/apikey
# Model: gemini-embedding-001 (3072 dimensions)
GEMINI_API_KEY=your_gemini_api_key_here