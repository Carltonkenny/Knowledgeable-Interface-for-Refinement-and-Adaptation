# .env.example
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Pollinations Gen API (Official)
# Get API key from: https://gen.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1
POLLINATIONS_MODEL_FULL=openai
POLLINATIONS_MODEL_FAST=nova

# Alternative: Groq API (optional, faster)
# GROQ_API_KEY=your_groq_api_key_here

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_KEY=your_service_role_key_here

# Frontend URLs (for CORS) - comma-separated list
# Localhost + production Koyeb URL
FRONTEND_URLS=http://localhost:3000,https://your-app.koyeb.app

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Optional: OpenAI API (if not using Pollinations)
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (for LangMem embeddings)
# Get API key from: https://aistudio.google.com/app/apikey
# Model: gemini-embedding-001 (3072 dimensions)
GEMINI_API_KEY=your_gemini_api_key_here

# ═══ RATE LIMITING (Cost Control) ═══════════════════════════
# Master toggle (true = enabled, false = disabled)
RATE_LIMIT_ENABLED=true

# Hourly limit (requests per hour per user)
RATE_LIMIT_HOURLY=10

# Daily limit (requests per day per user)
RATE_LIMIT_DAILY=50

# Monthly limit (requests per month per user)
RATE_LIMIT_MONTHLY=1500

# VIP users (comma-separated user IDs, bypass all limits)
RATE_LIMIT_EXEMPT_USERS=

# Environment (development = auto-disable rate limits)
ENVIRONMENT=production

# ═══ MONITORING (Sentry Error Tracking) ═══════════════════════
# Get DSN from: https://sentry.io/settings/your-org/projects/
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ═══ LANGSMITH (LLM Observability) ═══════════════════════
# NOTE: LangSmith requires a paid account for trace ingestion.
# Use LangFuse (below) for free self-hosted tracing.
# Get API key from: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_api_key_here
LANGCHAIN_PROJECT=promptforge-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ═══ LANGFUSE (Self-hosted LLM Observability) ════════════
# Dashboard: http://localhost:3001
# Auto-initialized via docker-compose LANGFUSE_INIT_* vars
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-kira
LANGFUSE_SECRET_KEY=sk-lf-kira

# ═══ OPENTELEMETRY (Infrastructure Tracing) ═══════════════
OTEL_ENABLED=false
OTEL_EXPORTER=jaeger
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:4317