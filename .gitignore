# ─────────────────────────────────────────────
# PromptForge v2.0 — Complete .gitignore
# ─────────────────────────────────────────────

# ═══ PYTHON ═══════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ═══ VIRTUAL ENVIRONMENT ═══════════════════════
venv/
ENV/
env/
.venv/

# ═══ ENVIRONMENT VARIABLES (NEVER COMMIT) ══════
.env
.env.local
.env.*.local
.env.sentry-build-plugin

# ═══ IDE ═══════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ═══ OS ════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
$null

# ═══ LOGS ══════════════════════════════════════
*.log
logs/

# ═══ TESTING ═══════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ═══ JUPYTER ═══════════════════════════════════
.ipynb_checkpoints

# ═══ DOCKER ════════════════════════════════════
docker-compose.override.yml

# ═══ NODE / NEXT.JS ════════════════════════════
**/node_modules/
promptforge-web/.next/
promptforge-web/out/
promptforge-web/.vercel/
promptforge-web/*.tsbuildinfo
promptforge-web/*.log

# ═══ QWEN CODE (LOCAL TOOL) ════════════════════
.qwen/
*.output

# ═══ TEMP / SCRATCH FILES ══════════════════════
# Test scripts (local development only)
quick_test_*.py
test_*.py
debug_*.py
diagnose_*.py
verify_*.py
investigate_*.py
check_*.py

# Temporary files
*.tmp
*.bak
.agent/ 
lighthouse-*.json
lighthouse-*.html
lint_output.txt
tsc_check.txt
